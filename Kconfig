module = LOW_POWER_SENSOR
module-str = Low Power Sensor
module-help = Low Power Sensor app

source "Kconfig.zephyr"

config LPS_EXPLICIT_LP_IMAGE_LOADING
    bool "Load the LP image based on directives within the application"
    default n
    help
        "enable explicit LP image loading"

config LPS_USE_LIGHT_SLEEP
    bool "Use light sleep rather than deep sleep for HP core"
    default n
    help
        "enable HP core light sleep mode"

config LPS_HPCORE_ALWAYS_STAY_AWAKE
    bool "Don't put the HP core to sleep (for debugging)"
    default n
    help
        "enable HP core don't sleep"

config LPS_MQTT_BROKER_ADDR
    string "MQTT broker address"
    default ""
    help
        "The address of the MQTT broker".

config LPS_MQTT_BROKER_PORT
    int "MQTT broker port"
    default 1883
    help
        "The UDP port of the MQTT broker".

config LPS_MQTT_BROKER_USERNAME
    string "MQTT broker username"
    default ""
    help
        "The username to connect to MQTT broker".

config LPS_MQTT_BROKER_PASSWORD
    string "MQTT broker password"
    default ""
    help
        "The password to connect to MQTT broker".

config LPS_DHCP_CLIENT
    bool "LPS DHCP client"
    default y
    help
        "enable LPS DHCP client"

config LPS_IP_ADDR
    string "Static IP Address"
    default "192.168.1.100"

config LPS_NETMASK
    string "Static Netmask"
    default "255.255.255.0"

config LPS_GW
    string "Static Gateway"
    default "192.168.1.1"