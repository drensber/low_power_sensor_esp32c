diff --git a/drivers/mbox/mbox_esp32.c b/drivers/mbox/mbox_esp32.c
index c9010b1d19a..1a58d47a843 100644
--- a/drivers/mbox/mbox_esp32.c
+++ b/drivers/mbox/mbox_esp32.c
@@ -123,6 +123,19 @@ IRAM_ATTR static void esp32_mbox_isr(const struct device *dev)
 	atomic_set(&dev_data->control->lock, ESP32_MBOX_LOCK_FREE_VAL);
 }
 
+static void memcpy_rtc_safe(volatile void *dest, const void *src, size_t num_bytes) {
+        // Cast both pointers to 32-bit integers
+        volatile uint32_t *d = (volatile uint32_t *)dest;
+	const uint32_t *s = (const uint32_t *)src;
+
+	// Calculate how many 32-bit words we need to copy
+	size_t num_words = num_bytes / 4;
+
+	for (size_t i = 0; i < num_words; i++) {
+	        d[i] = s[i]; // This forces a 32-bit 'sw' instruction!
+	}
+}
+
 static int esp32_mbox_send(const struct device *dev, mbox_channel_id_t channel,
 			   const struct mbox_msg *msg)
 {
@@ -151,7 +164,7 @@ static int esp32_mbox_send(const struct device *dev, mbox_channel_id_t channel,
 	if (msg != NULL && msg->data != NULL) {
 		uint8_t *dest = (dev_data->other_core_id == 0) ? dev_data->shm.pro_cpu_shm
 							       : dev_data->shm.app_cpu_shm;
-		memcpy(dest, msg->data, msg->size);
+		memcpy_rtc_safe(dest, msg->data, msg->size);
 	}
 
 	/* Only the lower 16bits of id are used */
